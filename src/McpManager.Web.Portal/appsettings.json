{
    "ConnectionStrings": {
        "ApplicationConnection": "Data Source=data/mcpmanager.db"
    },
    "Serilog": {
        "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft.AspNetCore": "Warning",
                "Microsoft.EntityFrameworkCore": "Warning"
            }
        },
        "WriteTo": [
            { "Name": "Console", "Args": { "restrictedToMinimumLevel": "Information" } },
            { "Name": "File", "Args": { "path": "data/logs/log.txt", "restrictedToMinimumLevel": "Warning", "rollingInterval": "Day", "retainedFileCountLimit": 30 } }
        ],
        "Enrich": ["FromLogContext"]
    },
    "AllowedHosts": "*"
}
