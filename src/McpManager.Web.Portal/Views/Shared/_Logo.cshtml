<svg width="200" height="28" viewBox="0 0 200 28" fill="none" xmlns="http://www.w3.org/2000/svg">
    <style>
        @@keyframes hub-pulse {
            0%, 100% { opacity: 1; r: 4; }
            50% { opacity: 0.7; r: 5; }
        }
        @@keyframes line-pulse {
            0%, 100% { opacity: 0.5; }
            50% { opacity: 1; }
        }
        @@keyframes node-pulse {
            0%, 100% { opacity: 0.6; }
            50% { opacity: 1; }
        }
        .hub { animation: hub-pulse 2.5s ease-in-out infinite; }
        .line { animation: line-pulse 2.5s ease-in-out infinite; }
        .node { animation: node-pulse 2.5s ease-in-out infinite; }
        .line-d1, .node-d1 { animation-delay: 0.3s; }
        .line-d2, .node-d2 { animation-delay: 0.6s; }
        .line-d3, .node-d3 { animation-delay: 0.9s; }
        .line-d4, .node-d4 { animation-delay: 1.2s; }
    </style>

    <!-- Connection lines from hub to satellite nodes -->
    <line class="line" x1="14" y1="14" x2="3" y2="3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
    <line class="line line-d1" x1="14" y1="14" x2="25" y2="3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
    <line class="line line-d2" x1="14" y1="14" x2="25" y2="25" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
    <line class="line line-d3" x1="14" y1="14" x2="3" y2="25" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
    <line class="line line-d4" x1="14" y1="14" x2="14" y2="1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>

    <!-- Satellite nodes -->
    <circle class="node" cx="3" cy="3" r="2.2" fill="currentColor"/>
    <circle class="node node-d1" cx="25" cy="3" r="2.2" fill="currentColor"/>
    <circle class="node node-d2" cx="25" cy="25" r="2.2" fill="currentColor"/>
    <circle class="node node-d3" cx="3" cy="25" r="2.2" fill="currentColor"/>
    <circle class="node node-d4" cx="14" cy="1" r="1.8" fill="currentColor"/>

    <!-- Central hub -->
    <circle class="hub" cx="14" cy="14" r="4" fill="currentColor"/>

    <!-- Text -->
    <text x="36" y="19" font-family="system-ui, -apple-system, sans-serif" font-size="16" font-weight="700" fill="currentColor">MCP Manager</text>
</svg>
