@{
    var exception = ViewData["Exception"] as Exception;
    var requestPath = ViewData["RequestPath"] as string;

    string BuildExceptionText() {
        if (exception == null) return "";

        var sb = new System.Text.StringBuilder();

        if (!string.IsNullOrEmpty(requestPath)) {
            sb.AppendLine($"Request Path:\n{requestPath}\n");
        }

        sb.AppendLine($"{exception.GetType().FullName}: {exception.Message}");

        if (!string.IsNullOrEmpty(exception.StackTrace)) {
            sb.AppendLine($"\nStack Trace\n{exception.StackTrace}");
        }

        var innerException = exception.InnerException;
        var depth = 1;
        while (innerException != null) {
            sb.AppendLine($"\nInner Exception {depth}: {innerException.GetType().FullName}");
            sb.AppendLine(innerException.Message);
            if (!string.IsNullOrEmpty(innerException.StackTrace)) {
                sb.AppendLine(innerException.StackTrace);
            }
            innerException = innerException.InnerException;
            depth++;
        }

        return sb.ToString();
    }

    var exceptionText = BuildExceptionText();
}

<div class="min-h-screen pt-5 pb-10">
    <div class="flex justify-center items-center mt-5">
        <div class="block text-center mt-5 w-full max-w-4xl px-4">
            <div class="block">
                <h1 class="title" style="font-size: 84px; color: #b30000;">@Html.Raw(ViewData["Title"])</h1>
            </div>

            @if (exception != null) {
                <div class="block mt-5 text-left">
                    <div class="flex justify-end mb-4">
                        <button type="button" id="copy-exception-btn" class="btn btn-sm btn-outline">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                            </svg>
                            Copy Exception
                        </button>
                    </div>
                    @if (!string.IsNullOrEmpty(requestPath)) {
                        <div class="alert alert-warning mb-4">
                            <span class="font-semibold">Request Path:</span> @requestPath
                        </div>
                    }

                    <div class="alert alert-error mb-4">
                        <div>
                            <span class="font-semibold">@exception.GetType().FullName:</span>
                            <span>@exception.Message</span>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(exception.StackTrace)) {
                        <div class="collapse collapse-arrow bg-base-200 mb-4">
                            <input type="checkbox" checked="checked" />
                            <div class="collapse-title font-semibold">Stack Trace</div>
                            <div class="collapse-content">
                                <pre class="text-xs overflow-x-auto whitespace-pre-wrap bg-base-300 p-4 rounded-lg">@exception.StackTrace</pre>
                            </div>
                        </div>
                    }

                    @{
                        var innerException = exception.InnerException;
                        var depth = 1;
                    }
                    @while (innerException != null) {
                        <div class="collapse collapse-arrow bg-base-200 mb-4">
                            <input type="checkbox" />
                            <div class="collapse-title font-semibold">Inner Exception @depth: @innerException.GetType().Name</div>
                            <div class="collapse-content">
                                <div class="alert alert-error mb-2">
                                    <span>@innerException.Message</span>
                                </div>
                                @if (!string.IsNullOrEmpty(innerException.StackTrace)) {
                                    <pre class="text-xs overflow-x-auto whitespace-pre-wrap bg-base-300 p-4 rounded-lg">@innerException.StackTrace</pre>
                                }
                            </div>
                        </div>
                        innerException = innerException.InnerException;
                        depth++;
                    }
                </div>
            }

            <div class="block mt-5">
                <a asp-action="Index" asp-controller="Home" class="btn btn-ghost">Back to dashboard</a>
            </div>
        </div>
    </div>
</div>

@if (exception != null) {
    <template id="exception-data">@exceptionText</template>

    <script>
        // Copy full exception details to clipboard
        document.getElementById('copy-exception-btn').addEventListener('click', function() {
            const exceptionText = document.getElementById('exception-data').innerHTML;
            const decoded = new DOMParser().parseFromString(exceptionText, 'text/html').documentElement.textContent;

            navigator.clipboard.writeText(decoded).then(() => {
                const btn = document.getElementById('copy-exception-btn');
                const originalHtml = btn.innerHTML;
                btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Copied!';
                btn.classList.add('btn-success');
                setTimeout(() => {
                    btn.innerHTML = originalHtml;
                    btn.classList.remove('btn-success');
                }, 2000);
            });
        });
    </script>
}
