@using McpManager.Core.Data.Models.Mcp
@model McpToolRequest

@functions {
    string FormatJson(string json) {
        if (string.IsNullOrWhiteSpace(json)) return "";
        try {
            var obj = System.Text.Json.JsonSerializer.Deserialize<System.Text.Json.JsonElement>(json);
            return System.Text.Json.JsonSerializer.Serialize(obj, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        } catch {
            return json;
        }
    }
}

@section PageActions {
    <a asp-action="Index" class="btn btn-ghost gap-2">
        <icon name="arrow-left" size="5" />
        <span class="hidden sm:inline">Back</span>
    </a>
}

<div class="grid grid-cols-12 gap-6">
    <div class="col-span-12 lg:col-span-5">
        <div class="card bg-base-100 border border-base-200 mb-4">
            <div class="card-body p-4">
                <h3 class="font-semibold text-sm">Request Info</h3>
                <div class="flex flex-col gap-2 text-sm mt-2">
                    <div>
                        <label class="text-xs text-base-content/60">Status</label>
                        <p>
                            @if (Model.Success) {
                                <span class="badge badge-success">Success</span>
                            } else {
                                <span class="badge badge-error">Error</span>
                            }
                        </p>
                    </div>
                    <div>
                        <label class="text-xs text-base-content/60">Tool</label>
                        <p class="font-medium">@Model.McpTool?.Name</p>
                    </div>
                    <div>
                        <label class="text-xs text-base-content/60">Server</label>
                        <p>@Model.McpTool?.McpServer?.Name</p>
                    </div>
                    <div>
                        <label class="text-xs text-base-content/60">API Key</label>
                        <p>@(Model.ApiKeyName ?? "—")</p>
                    </div>
                    <div>
                        <label class="text-xs text-base-content/60">Execution Time</label>
                        <p class="font-mono">@(Model.ExecutionTimeMs)ms</p>
                    </div>
                    <div>
                        <label class="text-xs text-base-content/60">Date</label>
                        <p>@Model.CreationTime.ToString("g")</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-span-12 lg:col-span-7">
        @if (!string.IsNullOrWhiteSpace(Model.Parameters)) {
            <div class="card bg-base-100 border border-base-200 mb-4">
                <div class="card-body p-4">
                    <h3 class="font-semibold text-sm">Parameters</h3>
                    <pre class="bg-base-200 rounded p-3 text-xs overflow-x-auto mt-2"><code>@FormatJson(Model.Parameters)</code></pre>
                </div>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.Response)) {
            <div class="card bg-base-100 border border-base-200">
                <div class="card-body p-4">
                    <h3 class="font-semibold text-sm">Response</h3>
                    <pre class="bg-base-200 rounded p-3 text-xs overflow-x-auto mt-2 max-h-96"><code>@FormatJson(Model.Response)</code></pre>
                </div>
            </div>
        }
    </div>
</div>
