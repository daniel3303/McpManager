@using McpManager.Core.Data.Models.Mcp
@using McpManager.Web.Portal.Dtos.Users
@using McpManager.Web.Portal.Extensions
@using NonFactors.Mvc.Grid
@model IQueryable<McpNamespace>

@{
    var filters = (TextSearchDto)ViewData["Filters"] ?? new TextSearchDto();
}

@section PageActions {
    <a asp-action="Create" class="btn btn-ghost gap-2">
        <icon name="plus" size="5" />
        <span class="hidden sm:inline">New</span>
    </a>
    <partial name="_HelpButton" />
    <partial name="_FilterButton" model="filters" />
}

@section FilterSidebar {
    <fieldset class="fieldset pb-0">
        <legend class="fieldset-legend">Search</legend>
        <input placeholder="Search namespaces" class="input w-full" asp-for="@filters.Search" />
    </fieldset>
}

@section HelpSidebar {
    <div class="space-y-4 text-sm">
        <div>
            <h3 class="font-semibold text-sm mb-1">Namespaces</h3>
            <p class="text-base-content/70">Namespaces let you group MCP servers and their tools into separate endpoints. Each namespace gets its own URL, so different AI clients or projects can access different sets of tools.</p>
        </div>
        <div>
            <h3 class="font-semibold text-sm mb-1">Why Use Namespaces?</h3>
            <ul class="list-disc list-inside text-base-content/70 space-y-1">
                <li>Expose only relevant tools per project or team</li>
                <li>Apply rate limits per namespace</li>
                <li>Override tool names and descriptions</li>
            </ul>
        </div>
        <div>
            <h3 class="font-semibold text-sm mb-1">Getting Started</h3>
            <p class="text-base-content/70">Click <strong>New</strong> to create a namespace, then add servers and configure which tools are enabled.</p>
        </div>
    </div>
}

@(Html
    .Grid(Model)
    .Build(columns => {
        columns.AddActivating();
        columns.AddActions(b => {
            b.AddShow();
            b.AddDelete();
        });
        columns.Add(model => model.Name).Titled("Name");
        columns.Add(model => model.Slug).Titled("Slug")
            .RenderedAs(m => $"<code class=\"text-sm\">{m.Slug}</code>")
            .Encoded(false);
        columns.Add(model => model.Servers.Count).Titled("Servers");
        columns.Add(model => model.Servers.Sum(s => s.Tools.Count(t => t.IsEnabled))).Titled("Tools");
        columns.Add(model => model.CreationTime).Titled("Created").Formatted("{0:g}");
    })
    .Using(GridFilterMode.Excel)
    .Empty(await Html.PartialAsync("_NoRecords", "No namespaces found."))
    .Sortable()
    .Pageable()
)
