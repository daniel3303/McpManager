@using McpManager.Core.Data.Models.Identity
@model McpManager.Web.Portal.Dtos.Account.ChangePasswordDto

@{
    var user = ViewData["User"] as User;
}

<form asp-action="ChangePassword">
    <div asp-validation-summary="ModelOnly" class="alert alert-error mb-4"></div>

    <div class="grid grid-cols-12 gap-6">
        <!-- Info Cards - Left Column -->
        <div class="col-span-12 lg:col-span-5">
            <!-- User Info Card -->
            <div class="card bg-base-100 border border-base-200 mb-4">
                <div class="card-body p-4">
                    <h3 class="fieldset-legend">Account</h3>
                    <div class="flex items-center gap-4 mt-2">
                        <div class="avatar placeholder">
                            <div class="bg-neutral text-neutral-content w-12 rounded-full flex items-center justify-center">
                                <span class="text-lg">@(user?.GivenName?.Substring(0, 1).ToUpper() ?? "U")</span>
                            </div>
                        </div>
                        <div>
                            <div class="font-medium">@user?.FullName</div>
                            <div class="text-sm text-base-content/60">@user?.Email</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Password Requirements Card -->
            <div class="card bg-base-100 border border-base-200">
                <div class="card-body p-4">
                    <h3 class="fieldset-legend">Password Requirements</h3>
                    <ul class="text-sm text-base-content/70 mt-2 space-y-1">
                        <li class="flex items-center gap-2">
                            <icon name="check-circle" size="4" class="text-success" />
                            At least 6 characters
                        </li>
                        <li class="flex items-center gap-2">
                            <icon name="check-circle" size="4" class="text-success" />
                            Mix of letters and numbers recommended
                        </li>
                        <li class="flex items-center gap-2">
                            <icon name="check-circle" size="4" class="text-success" />
                            Avoid common passwords
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Password Form - Right Column -->
        <div class="col-span-12 lg:col-span-7">
            <div class="card bg-base-100 border border-base-200">
                <div class="card-body p-4">
                    <h3 class="fieldset-legend">New Password</h3>
                    <p class="text-xs text-base-content/60 mb-2">Enter and confirm your new password.</p>
                    <div class="grid grid-cols-12 gap-3">
                        <form-field asp-for="NewPassword" class="col-span-12 md:col-span-6" />
                        <form-field asp-for="ConfirmPassword" class="col-span-12 md:col-span-6" />
                    </div>
                </div>
            </div>

            <partial name="Form/_ActionButtons" />
        </div>
    </div>
</form>
