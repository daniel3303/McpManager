@section PageActions {
    <partial name="_HelpButton" />
}

@{
    var totalServers = (int)ViewData["TotalServers"];
    var activeServers = (int)ViewData["ActiveServers"];
    var totalTools = (int)ViewData["TotalTools"];
    var totalApiKeys = (int)ViewData["TotalApiKeys"];
}

<!-- Summary Cards -->
<div class="grid grid-cols-3 gap-4">
    <div class="card bg-base-100 border border-base-200">
        <div class="card-body p-4">
            <div class="flex items-center gap-3">
                <div class="size-10 rounded-lg bg-primary/10 flex items-center justify-center">
                    <icon name="server-stack" size="5" class="text-primary" />
                </div>
                <div class="flex-1 min-w-0">
                    <label class="text-xs text-base-content/60">MCP Servers</label>
                    <p class="text-xl font-semibold">@activeServers <span class="text-sm font-normal text-base-content/50">/ @totalServers</span></p>
                </div>
            </div>
        </div>
    </div>

    <div class="card bg-base-100 border border-base-200">
        <div class="card-body p-4">
            <div class="flex items-center gap-3">
                <div class="size-10 rounded-lg bg-success/10 flex items-center justify-center">
                    <icon name="wrench-screwdriver" size="5" class="text-success" />
                </div>
                <div class="flex-1 min-w-0">
                    <label class="text-xs text-base-content/60">Tools</label>
                    <p class="text-xl font-semibold">@totalTools</p>
                </div>
            </div>
        </div>
    </div>

    <div class="card bg-base-100 border border-base-200">
        <div class="card-body p-4">
            <div class="flex items-center gap-3">
                <div class="size-10 rounded-lg bg-warning/10 flex items-center justify-center">
                    <icon name="key" size="5" class="text-warning" />
                </div>
                <div class="flex-1 min-w-0">
                    <label class="text-xs text-base-content/60">Active API Keys</label>
                    <p class="text-xl font-semibold">@totalApiKeys</p>
                </div>
            </div>
        </div>
    </div>
</div>

<partial name="_ConnectTools" model="@("/mcp")" />

@section HelpSidebar {
    <div class="space-y-4 text-sm">
        <div>
            <h3 class="font-semibold text-sm mb-1">Dashboard Overview</h3>
            <p class="text-base-content/70">This is your MCP Manager home page showing a quick summary of your setup.</p>
        </div>
        <div>
            <h3 class="font-semibold text-sm mb-1">Summary Cards</h3>
            <ul class="list-disc list-inside text-base-content/70 space-y-1">
                <li><strong>MCP Servers</strong> &mdash; active vs total registered servers</li>
                <li><strong>Tools</strong> &mdash; total tools synced across all servers</li>
                <li><strong>API Keys</strong> &mdash; number of active API keys</li>
            </ul>
        </div>
        <div>
            <h3 class="font-semibold text-sm mb-1">Connect to Your Tools</h3>
            <p class="text-base-content/70">Use the connection snippets at the bottom to configure your AI client (Claude Desktop, Cursor, etc.) to connect to MCP Manager's unified endpoint.</p>
        </div>
    </div>
}
